{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "My shareable Renovate config",
  "extends": [
    "config:recommended",
    "group:test",
    "group:vite",
    ":maintainLockFilesWeekly",
    ":semanticCommitTypeAll(chore)",
    "schedule:earlyMondays"
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 0,
  "labels": [
    "dependencies"
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "enabled": true
  },
  "packageRules": [
    {
      "groupName": "patch-level",
      "matchPackageNames": [
        "*"
      ],
      "matchUpdateTypes": [
        "patch"
      ]
    },
    {
      "groupName": "validators",
      "matchPackageNames": [
        "@vee-validate/**",
        "yup",
        "zod"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "groupName": "@iconify-json",
      "matchPackageNames": [
        "@iconify-json/**"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "groupName": "three.js",
      "matchPackageNames": [
        "@tresjs/**",
        "three"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "groupName": "eslint",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchPackageNames": [
        "/^eslint$/",
        "/^@.*eslint.*$/"
      ]
    },
    {
      "groupName": "tailwindcss",
      "matchPackageNames": [
        "daisyui",
        "/^.*tailwindcss.*$/"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ]
}
